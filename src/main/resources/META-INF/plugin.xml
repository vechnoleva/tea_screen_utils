<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>org.example.tea_rename_screen.rename-screen</id>
    <name>Rename Screen</name>
    <vendor url="https://github.com">Developer</vendor>

    <description><![CDATA[
        Renames all artifacts of an Android MVP/MVI screen in one operation:<br/>
        Fragment, Presenter, Contract, Params, Mapper, Adapter, DI, layout file, and the Screens entry.
    ]]></description>

    <!-- Core platform APIs (PSI, refactoring, etc.) -->
    <depends>com.intellij.modules.platform</depends>
    <!-- Java/Kotlin PSI (PsiClass, PsiShortNamesCache, RenameProcessor, …) -->
    <depends>com.intellij.modules.java</depends>
    <!-- Android-specific support (always present in Android Studio) -->
    <depends>org.jetbrains.android</depends>
    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Rename Screen" displayType="BALLOON"/>
    </extensions>

    <actions>
        <action id="org.example.tea_rename_screen.RenameScreenAction"
                class="org.example.tea_rename_screen.RenameScreenAction"
                text="Rename Screen (All Files)"
                description="Renames all artifacts of an Android screen: Fragment, Presenter, Contract, layout, etc.">
            <!-- Available via right-click in the code editor -->
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <!-- Available via right-click in the Project tree -->
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
